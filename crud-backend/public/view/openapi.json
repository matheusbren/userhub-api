{
  "openapi": "3.0.3",
  "info": {
    "title": "UserHub API",
    "description": "API CRUD de usuários em PHP com persistência em JSON.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Servidor local"
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "Operações de usuários"
    }
  ],
  "paths": {
    "/api/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Listar usuários",
        "responses": {
          "200": {
            "description": "Lista de usuários",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "users": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/User"
                      }
                    }
                  }
                },
                "example": {
                  "users": [
                    {
                      "id": 1,
                      "name": "João",
                      "age": 25,
                      "email": "joao@email.com"
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Criar usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Atualizar usuário (completo)",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserIdQuery"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Usuário atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/UserNotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "patch": {
        "tags": ["Users"],
        "summary": "Atualizar usuário (parcial)",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserIdQuery"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserPatchInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Usuário atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/UserNotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Excluir usuário",
        "parameters": [
          {
            "$ref": "#/components/parameters/UserIdQuery"
          }
        ],
        "responses": {
          "200": {
            "description": "Usuário removido",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/UserNotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "UserIdQuery": {
        "name": "id",
        "in": "query",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "ID do usuário"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "required": ["id", "name", "age", "email"],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "example": "João"
          },
          "age": {
            "type": "integer",
            "minimum": 1,
            "maximum": 150,
            "example": 25
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "joao@email.com"
          }
        }
      },
      "UserCreateInput": {
        "type": "object",
        "required": ["name", "age", "email"],
        "properties": {
          "name": {
            "type": "string",
            "example": "João"
          },
          "age": {
            "type": "integer",
            "example": 25
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "joao@email.com"
          }
        }
      },
      "UserPatchInput": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "name": {
            "type": "string"
          },
          "age": {
            "type": "integer"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string",
            "example": "Invalid JSON body"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Erro de validação/requisição",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "UserNotFound": {
        "description": "Usuário não encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "User not found"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Erro interno",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "error": "Internal server error"
            }
          }
        }
      }
    }
  }
}